{
  "kind": "collectionType",
  "collectionName": "partners",
  "info": {
    "singularName": "partner",
    "pluralName": "partners",
    "displayName": "Partner",
    "description": "Technology and solution partners"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "description": {
      "type": "text",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "website_url": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "tier": {
      "type": "enumeration",
      "enum": ["Strategic", "Technology", "Solution"],
      "default": "Technology",
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "sort_order": {
      "type": "integer",
      "default": 0,
      "pluginOptions": { "i18n": { "localized": false } }
    }
  }
}