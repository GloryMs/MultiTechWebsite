{
  "kind": "singleType",
  "collectionName": "about_pages",
  "info": {
    "singularName": "about-page",
    "pluralName": "about-pages",
    "displayName": "About Page",
    "description": "Content for the About Us page: story, vision, mission, timeline, values, and team"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
